# Local development environment
# Copy to .env and adjust as needed

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Local Postgres in Docker (port 5433 to avoid conflict)
DATABASE_URL=postgresql://fuzex_api_dev:devpassword@localhost:5433/fuzex_social_dev

# Dev handle domain
HANDLE_DOMAIN=.dev.fuzex.social
PDS_URL=https://pds.dev.fuzex.social

CORS_ALLOWED_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Phase 2: Firebase — for local dev, point at the dev service account file.
# Tests mock Firestore/Auth, so the file does not need to exist for `npm test`.
FIREBASE_PROJECT_ID=fuzex-41211
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-dev-service-account.json

# Phase 2: PDS admin — values match the dev PDS admin password
PDS_ADMIN_USERNAME=admin
PDS_ADMIN_PASSWORD=devadminpassword
PDS_INVITE_REQUIRED=false

# Phase 2: user defaults
DEFAULT_WALLET_CHAIN=ethereum
SYNTHETIC_EMAIL_DOMAIN=email.fuzex.social
MIN_USER_AGE=13

# Phase 2: encryption key for per-user PDS passwords (DEV ONLY — production uses a real strong key)
PDS_PASSWORD_ENCRYPTION_KEY=dev-key-must-be-at-least-32-characters-long-for-aes
