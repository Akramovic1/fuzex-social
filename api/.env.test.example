# Test environment
# Copy to .env.test and adjust if needed
# Tests use a SEPARATE database to avoid colliding with dev data

NODE_ENV=test
PORT=3099
LOG_LEVEL=warn

# Test DB on the same Postgres instance, different database name
DATABASE_URL=postgresql://fuzex_api_dev:devpassword@localhost:5433/fuzex_social_test

HANDLE_DOMAIN=.dev.fuzex.social
PDS_URL=https://pds.dev.fuzex.social

CORS_ALLOWED_ORIGINS=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100000
