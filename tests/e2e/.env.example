# E2E test suite — copy to .env and fill in.
# All values shown below are the defaults for the dev backend.

# === Targets ===
# Override these to point at production when ready.
E2E_API_BASE=https://dev-api.fuzex.social
E2E_PDS_BASE=https://pds.dev.fuzex.social

# === Firebase ===
# Public Firebase web API key (also embedded in mobile apps; safe to commit).
FIREBASE_WEB_API_KEY=AIzaSyBu8maDKNbeesBWSiWa3fHvLA7_5UKNeTw
# Path to the firebase service account JSON. Relative to tests/e2e/ or absolute.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# === Existing test user (t100) ===
# Layer 1 + Layer 2 verify against this fixed user. Layer 3 creates new users.
E2E_TEST_USER_UID=eumhZym9FyRdH7hww6kCVKLm3rv2
E2E_TEST_USER_HANDLE=t100.dev.fuzex.social
E2E_TEST_USER_DID=did:plc:4nohhpere4ka5gisniie6nxh
E2E_TEST_USER_WALLET=0xb898862cc1aede4e183cd1014c8730e325df798c

# === Optional: PDS admin verification in Layer 3 step 6 ===
# If unset, that step is skipped (test logs "skipped" and passes).
# PDS_ADMIN_PASSWORD=

# === Optional: prefix for dynamically-generated Layer 3 test users ===
# Leftover Postgres + PDS rows can be cleaned up with this prefix.
E2E_USER_PREFIX=e2e
