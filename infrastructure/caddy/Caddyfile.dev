# Dev VPS Caddy config — fuzex.social domain.
#
# Replaces the previous fuzex.app version (see docs/vps-dev-setup-history.md
# Step 10 and ADR 0007 for the migration rationale). The fuzex.app domain
# stays reserved for the marketing site and main app; everything atproto/
# social-related lives under fuzex.social.
#
# IMPORTANT: pds.dev.fuzex.social is intentionally combined with the
# *.dev.fuzex.social wildcard block (matching Bluesky's bsky.social reference
# pattern). When a managed-cert sibling block AND a wildcard block both match
# the same hostname, Caddy's policy resolution silently breaks proactive cert
# obtain — TLS handshakes then fall through to on-demand and fail because the
# cert was never acquired. Combining them into one on-demand-TLS block gated
# by PDS /tls-check (which approves both PDS itself and registered handles)
# is the only pattern that works reliably.
#
# Last updated: 2026-05-06

{
	email tech@fuzex.io
	on_demand_tls {
		ask http://localhost:3000/tls-check
	}
}

# fuzex-api — eager managed Let's Encrypt cert (sibling, not under wildcard).
dev-api.fuzex.social {
	reverse_proxy http://localhost:3001 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# PDS hostname + user handle subdomains — on-demand TLS gated by /tls-check.
# PDS approves its own hostname AND registered user handles via /tls-check.
pds.dev.fuzex.social, *.dev.fuzex.social {
	tls {
		on_demand
	}

	# PDS itself reverse-proxies to the Bluesky PDS container.
	@pds host pds.dev.fuzex.social
	handle @pds {
		reverse_proxy http://localhost:3000
	}

	# User handle subdomains only respond to /.well-known/atproto-did.
	@wellknown path /.well-known/atproto-did
	handle @wellknown {
		reverse_proxy http://localhost:3001 {
			header_up Host {host}
		}
	}

	handle {
		respond 404
	}
}
