{
	email tech@fuzex.io
	on_demand_tls {
		ask http://localhost:3000/tls-check
	}
}

# Bluesky PDS — moved out from under the *.dev.fuzex.app wildcard
# to its own sibling subdomain to avoid TLS policy collisions.
*.dev-pds.fuzex.app, dev-pds.fuzex.app {
	tls {
		on_demand
	}
	reverse_proxy http://localhost:3000
}

# fuzex-api — sibling subdomain, normal Let's Encrypt cert (no on-demand)
dev-api.fuzex.app {
	reverse_proxy http://localhost:3001 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# User handle subdomains (akram.dev.fuzex.app, etc.) — only thing left
# under the wildcard now. Routes /.well-known/atproto-did to fuzex-api.
*.dev.fuzex.app {
	tls {
		on_demand
	}

	@wellknown path /.well-known/atproto-did
	handle @wellknown {
		reverse_proxy http://localhost:3001 {
			header_up Host {host}
		}
	}

	handle {
		respond 404
	}
}
