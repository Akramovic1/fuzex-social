{
	email tech@fuzex.io
	on_demand_tls {
		ask http://localhost:3000/tls-check
	}
}

# Bluesky PDS — kept at original hostname so akram's PLC document
# and federation cache remain valid.
*.pds.dev.fuzex.app, pds.dev.fuzex.app {
	tls {
		on_demand
	}
	reverse_proxy http://localhost:3000
}

# fuzex-api — sibling subdomain (NOT under *.dev.fuzex.app wildcard).
# Caddy auto-issues a normal Let's Encrypt cert at startup.
dev-api.fuzex.app {
	reverse_proxy http://localhost:3001 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# User handle subdomains (akram.dev.fuzex.app, etc.) — on-demand TLS
# gated by PDS's /tls-check (only registered handles get certs).
*.dev.fuzex.app {
	tls {
		on_demand
	}

	@wellknown path /.well-known/atproto-did
	handle @wellknown {
		reverse_proxy http://localhost:3001 {
			header_up Host {host}
		}
	}

	handle {
		respond 404
	}
}
